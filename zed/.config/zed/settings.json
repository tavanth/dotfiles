{
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
      "enable_thinking": true,
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-haiku-4.5",
        "enable_thinking": true,
      },
    ],
    "model_parameters": [],
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "icon_theme": "Bearded Icon Theme",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "base_keymap": "VSCode",
  "tab_bar": {
    "show": false,
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "minimap": {
    "show": "never",
  },
  "scrollbar": {
    "axes": {
      "horizontal": false,
      "vertical": false,
    },
  },
  "buffer_font_fallbacks": ["Menlo", "Monaco", "Courier New", "monospace"],
  "buffer_font_family": "MonaspiceNe Nerd Font",
  "font_ligatures": false,
  "indent_guides": {
    "enabled": false,
  },
  "agent_servers": {
    "github-copilot-cli": {
      "default_config_options": {
        "reasoning_effort": "high",
        "mode": "https://agentclientprotocol.com/protocol/session-modes#agent",
        "model": "gemini-3.1-pro-preview"
      },
      "type": "registry",
    },
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Kanso Ink (Borderless + No italics)",
  },
}
